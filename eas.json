{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://bexevo-production.up.railway.app/",
        "EXPO_PUBLIC_BETTER_AUTH_URL": "https://bexevo-production.up.railway.app/"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://bexevo-production.up.railway.app/",
        "EXPO_PUBLIC_BETTER_AUTH_URL": "https://bexevo-production.up.railway.app/"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://bexevo-production.up.railway.app/",
        "EXPO_PUBLIC_BETTER_AUTH_URL": "https://bexevo-production.up.railway.app/"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
