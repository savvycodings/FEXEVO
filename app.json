{
  "expo": {
    "name": "xevo",
    "slug": "xevo",
    "scheme": "xevo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xevo.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "FacebookAppID": "3843873549080105",
        "FacebookDisplayName": "xevo paddle",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "xevo"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "fb3843873549080105"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.xevo.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "124b74b4-5931-4ee3-96fe-ddc01a4459c0"
      }
    }
  }
}
