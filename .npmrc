# pnpm 9.x: behavior settings live here (.npmrc).
# pnpm 11+ can also use pnpm-workspace.yaml — keep both in sync.
#
# Flat node_modules (no .pnpm/<hash>/node_modules/...) — required on Windows
# so CMake/Ninja paths stay under ~260 chars for react-native-worklets etc.
node-linker=hoisted
package-import-method=copy
